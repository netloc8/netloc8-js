        "react",
        "react-hook",
        "geolocation",
        "ip-geolocation",
        "geoip",
        "useGeo",
        "GeoGate",
        "eu-detection",
        "gdpr",
        "cookie-consent",
        "country-detection",
        "location-detection",
        "geo-blocking",
        "timezone",
        "react-context",
        "netloc8"
    ],
    "homepage": "https://netloc8.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/netloc8/netloc8-js",
        "directory": "packages/react"
    },
    "type": "module",
    "sideEffects": false,
    "license": "Elastic-2.0",
    "exports": {
        ".": {
            "bun": "./src/index.ts",
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.mts"
        }
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "tsdown",

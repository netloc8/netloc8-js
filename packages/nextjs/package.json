{
    "name": "@netloc8/nextjs",
    "version": "1.0.0",
    "description": "Next.js geolocation plugin. Server-side proxy, getGeo() for Server Components, useGeo() hook, GeoGate, and locale-based redirects.",
    "keywords": [
        "nextjs",
        "next",
        "next-plugin",
        "geolocation",
        "ip-geolocation",
        "geoip",
        "server-components",
        "app-router",
        "middleware",
        "proxy",
        "ssr",
        "timezone",
        "eu-detection",
        "gdpr",
        "locale-redirect",
        "geo-blocking",
        "cookie-consent",
        "location-detection",
        "netloc8"
    ],
    "homepage": "https://netloc8.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/netloc8/netloc8-js",
        "directory": "packages/nextjs"
    },
    "type": "module",
    "license": "Elastic-2.0",
    "exports": {
        ".": {
            "bun": "./src/index.ts",
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.mts"
        },
        "./proxy": {
            "bun": "./src/proxy.ts",
            "import": "./dist/proxy.mjs",
            "types": "./dist/proxy.d.mts"
        },
        "./server": {
            "bun": "./src/server.ts",
            "import": "./dist/server.mjs",
            "types": "./dist/server.d.mts"
        }
    },
    "files": [
        "dist/",
        "proxy/",
        "server/"
    ],
    "scripts": {
        "build": "tsdown",
        "clean": "rm -rf dist",
        "test": "bun test src/"
    },
    "peerDependencies": {
        "next": ">=16.0.0",
        "react": ">=19.0.0"
    },
    "dependencies": {
        "@netloc8/core": "workspace:*",
        "@netloc8/react": "workspace:*"
    },
    "engines": {
        "node": ">=18"
    }
}
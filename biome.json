{
    "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "correctness": {
                "noUnusedImports": "warn"
            }
        }
    },
    "files": {
        "includes": [
            "packages/*/src/**",
            "packages/*/package.json",
            "package.json",
            "biome.json"
        ]
    }
}
